{
  "manifest_version": 3,
  "name": "Mineparser",
  "version": "0.1.0",
  "description": "Keyboard-first prompt and command launcher.",
  "action": { "default_title": "Open Mineparser", "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" } },
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "background": { "service_worker": "background.js", "type": "module" },
  "commands": {
    "open-mineparser": {
      "suggested_key": { "default": "Ctrl+Shift+Space", "mac": "MacCtrl+Shift+Space" },
      "description": "Open Mineparser"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_start" }],
  "web_accessible_resources": [{ "resources": ["app.html", "app.css", "app.js", "assets/*"], "matches": ["<all_urls>"] }]
}
